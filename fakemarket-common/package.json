{
  "name": "fakemarket-common",
  "version": "1.0.0",
  "private": true,
  "description": "Internal shared library for FakeMarket domain, database, repositories, and services.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./models/*": {
      "types": "./dist/models/*.d.ts",
      "default": "./dist/models/*.js"
    },
    "./repositories/*": {
      "types": "./dist/repositories/*.d.ts",
      "default": "./dist/repositories/*.js"
    },
    "./services/*": {
      "types": "./dist/services/*.d.ts",
      "default": "./dist/services/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "db/*": [
        "dist/db/*.d.ts"
      ],
      "models/*": [
        "dist/models/*.d.ts"
      ],
      "repositories/*": [
        "dist/repositories/*.d.ts"
      ],
      "services/*": [
        "dist/services/*.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
